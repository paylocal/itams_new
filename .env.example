# .env.example
# ============================================================
# Copy file này thành .env và điền giá trị phù hợp với môi trường
# của bạn. KHÔNG được commit file .env chứa thông tin thật.
# ============================================================

# ============================================================
# Database (SQL Server via Prisma)
# ============================================================
# Mặc định dùng SQL Server local để dễ backup/restore.
# Thay YOUR_PASSWORD bằng password sa của SQL Server trên máy bạn.
#
# Nếu dùng SQL Server Express, bỏ comment dòng bên dưới:
# DATABASE_URL="sqlserver://localhost\SQLEXPRESS:1433;database=itams;user=sa;password=YOUR_PASSWORD;encrypt=true;trustServerCertificate=true"
DATABASE_URL="sqlserver://localhost:1433;database=itams;user=sa;password=YOUR_PASSWORD;encrypt=true;trustServerCertificate=true"

# ============================================================
# NextAuth.js
# ============================================================
# Secret dùng để ký và mã hóa session/token.
# Tạo secret ngẫu nhiên bằng lệnh: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-key"

# URL của ứng dụng khi chạy local.
# Nếu chạy trong mạng LAN, thay bằng IP máy host.
NEXTAUTH_URL="http://localhost:3000"
